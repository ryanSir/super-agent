        <mxCell id="platform_policy" value="10. 权限检查&#xa;Policy Engine&#xa;policy.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#111827;" parent="1" vertex="1">
