        <mxCell id="agent_discover" value="8. 发现可用能力&#xa;list-capabilities / list-skills&#xa;Capability Resolver" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#111827;" parent="1" vertex="1">
