        <mxCell id="agent_task" value="7. 业务 Agent 收到任务&#xa;用户问题 / 业务流程触发" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#111827;" parent="1" vertex="1">
          <mxGeometry x="100" y="390" width="190" height="66" as="geometry" />
