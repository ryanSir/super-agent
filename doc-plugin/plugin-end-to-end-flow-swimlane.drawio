        <mxCell id="manager_enable" value="6. 启用 / 绑定&#xa;workspace / agent&#xa;Capability Index" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#111827;" parent="1" vertex="1">
          <mxGeometry x="1030" y="248" width="190" height="68" as="geometry" />
