        <mxCell id="agent_answer" value="16. Agent 生成回答&#xa;结构化结果 + skill context&#xa;返回用户 / 触发动作" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#111827;" parent="1" vertex="1">
