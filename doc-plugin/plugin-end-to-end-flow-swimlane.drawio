        <mxCell id="dev_publish" value="3. 发布插件&#xa;publish&#xa;publisher.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#111827;" parent="1" vertex="1">
          <mxGeometry x="545" y="118" width="170" height="64" as="geometry" />
        </mxCell>
        <mxCell id="registry_store" value="4. Registry 存储&#xa;package.zip / metadata&#xa;local registry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#111827;" parent="1" vertex="1">
          <mxGeometry x="540" y="248" width="180" height="68" as="geometry" />
        </mxCell>
        <mxCell id="manager_install" value="5. 安装插件&#xa;install&#xa;manager.install_plugin" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#111827;" parent="1" vertex="1">
          <mxGeometry x="790" y="248" width="180" height="68" as="geometry" />
